# ─────────────────────────────────────────────────
# Discord Bot Configuration
# ─────────────────────────────────────────────────

# Your bot's token from the Discord Developer Portal
# https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# The ID of the guild (server) the bot operates in
GUILD_ID=123456789012345678

# ─────────────────────────────────────────────────
# Voice Channel Monitor
# ─────────────────────────────────────────────────

# The voice channel the bot will permanently sit in and monitor
VOICE_CHANNEL_ID=123456789012345678

# The text channel where join notifications are sent
NOTIFICATION_CHANNEL_ID=123456789012345678

# Comma-separated list of Discord User IDs to ping when someone joins
# Example: 111111111111111111,222222222222222222,333333333333333333
USERS_TO_PING=111111111111111111,222222222222222222

# ─────────────────────────────────────────────────
# GitHub Webhook Receiver
# ─────────────────────────────────────────────────

# The text channel where new GitHub issue embeds are posted
ANNOUNCEMENT_CHANNEL_ID=123456789012345678

# Port for the Express webhook server (defaults to 3000)
PORT=3000
